# TraderNet Client - Expo Environment Variables Template
# Copy this file to a new file named '.env' in this directory.

# The base URL of the backend API tunnel (replace with your ngrok URL)
EXPO_PUBLIC_API_URL=https://YOUR_SUBDOMAIN.ngrok-free.app/api

# The base URL of the socket.io connection (replace with your ngrok URL)
EXPO_PUBLIC_SOCKET_URL=https://YOUR_SUBDOMAIN.ngrok-free.app

# The base URL of the backend web server for statistics pages
EXPO_PUBLIC_WEB_URL=https://YOUR_SUBDOMAIN.ngrok-free.app
